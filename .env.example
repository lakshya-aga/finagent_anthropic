# Lakshya QAI Configuration
# Copy this to .env and fill in your values

# Anthropic API Key (required for Claude Agent SDK)
ANTHROPIC_API_KEY=sk-ant-...

# GROBID server URL (run via Docker: docker run -p 8070:8070 lfoppiano/grobid:0.8.0)
QAI_GROBID_URL=http://localhost:8070

# Signal API
QAI_SIGNAL_API_HOST=0.0.0.0
QAI_SIGNAL_API_PORT=8000

# Models (sonnet, opus, haiku)
QAI_PLANNING_MODEL=sonnet
QAI_CODING_MODEL=sonnet
QAI_TESTING_MODEL=sonnet
QAI_CLASSIFIER_MODEL=haiku
QAI_BIAS_AUDIT_MODEL=sonnet

# Budget caps (USD per agent invocation)
QAI_PLANNING_BUDGET=1.0
QAI_CODING_BUDGET=2.0
QAI_TESTING_BUDGET=2.0

# Classifier confidence threshold
QAI_CLASSIFIER_CONFIDENCE_THRESHOLD=0.80

# Embedding model for vector store
QAI_EMBEDDING_MODEL=all-MiniLM-L6-v2
